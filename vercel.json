{
  "framework": "create-react-app",
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "rewrites": [
    {
      "source": "/api/suggest",
      "destination": "/api/suggest.js"
    },
    {
      "source": "/api/v1/suggest",
      "destination": "/api/suggest.js?v=1"
    },
    {
      "source": "/api/planner",
      "destination": "/api/planner.js"
    },
    {
      "source": "/api/payments",
      "destination": "/api/payments.js"
    },
    {
      "source": "/api/meal-history",
      "destination": "/api/meal-history.js"
    },
    {
      "source": "/api/detect-ingredients",
      "destination": "/api/detect-ingredients.js"
    },
    {
      "source": "/api/comms",
      "destination": "/api/comms.js"
    },
    {
      "source": "/api/stats",
      "destination": "/api/stats.js"
    },
    {
      "source": "/api/admin",
      "destination": "/api/admin.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}