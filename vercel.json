{
  "version": 2,
  "builds": [
    { "src": "package.json",              "use": "@vercel/static-build", "config": { "distDir": "build" } },
    { "src": "api/suggest.js",            "use": "@vercel/node" },
    { "src": "api/planner.js",            "use": "@vercel/node" },
    { "src": "api/create-order.js",       "use": "@vercel/node" },
    { "src": "api/verify-payment.js",     "use": "@vercel/node" },
    { "src": "api/meal-history.js",       "use": "@vercel/node" },
    { "src": "api/detect-ingredients.js", "use": "@vercel/node" },
    { "src": "api/feedback.js",           "use": "@vercel/node" },
    { "src": "api/email-subscribe.js",    "use": "@vercel/node" },
    { "src": "api/v1/suggest.js",         "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/suggest",              "dest": "/api/suggest.js" },
    { "src": "/api/planner",              "dest": "/api/planner.js" },
    { "src": "/api/create-order",         "dest": "/api/create-order.js" },
    { "src": "/api/verify-payment",       "dest": "/api/verify-payment.js" },
    { "src": "/api/meal-history",         "dest": "/api/meal-history.js" },
    { "src": "/api/detect-ingredients",   "dest": "/api/detect-ingredients.js" },
    { "src": "/api/feedback",             "dest": "/api/feedback.js" },
    { "src": "/api/email-subscribe",      "dest": "/api/email-subscribe.js" },
    { "src": "/api/v1/suggest",           "dest": "/api/v1/suggest.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
