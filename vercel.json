{
  "framework": "create-react-app",
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "rewrites": [
    {
      "source": "/api/suggest",
      "destination": "/api/suggest.js"
    },
    {
      "source": "/api/planner",
      "destination": "/api/planner.js"
    },
    {
      "source": "/api/create-order",
      "destination": "/api/create-order.js"
    },
    {
      "source": "/api/verify-payment",
      "destination": "/api/verify-payment.js"
    },
    {
      "source": "/api/meal-history",
      "destination": "/api/meal-history.js"
    },
    {
      "source": "/api/detect-ingredients",
      "destination": "/api/detect-ingredients.js"
    },
    {
      "source": "/api/feedback",
      "destination": "/api/feedback.js"
    },
    {
      "source": "/api/email-subscribe",
      "destination": "/api/email-subscribe.js"
    },
    {
      "source": "/api/v1/suggest",
      "destination": "/api/v1/suggest.js"
    },
    {
      "source": "/api/stats",
      "destination": "/api/stats.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}