{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    },
    {
      "src": "api/suggest.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/planner.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/suggest", "dest": "/api/suggest.js" },
    { "src": "/api/planner", "dest": "/api/planner.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
