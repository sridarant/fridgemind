# Anthropic API (server-side only)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Supabase (public key safe for frontend)
REACT_APP_SUPABASE_URL=https://your-project-id.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase service role key (server-side only — never expose)
# Used by api/meal-history.js to bypass RLS for server operations
# Get from: Supabase → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Razorpay — India payments
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
REACT_APP_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx

# YouTube Data API v3 (for recipe video search — server-side only)
YOUTUBE_API_KEY=your_youtube_api_key
