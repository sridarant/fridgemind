# Anthropic API (server-side only)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Supabase (safe for frontend)
REACT_APP_SUPABASE_URL=https://your-project-id.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Razorpay — India payments (server-side secret, public key safe for frontend)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
REACT_APP_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx

# Stripe — International payments (server-side secret, public key safe for frontend)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx
